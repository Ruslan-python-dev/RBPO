<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    
    <!-- Исключения для тестовых зависимостей -->
    <suppress>
        <notes><![CDATA[
            Тестовые зависимости не попадают в production
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org.springframework.boot/spring-boot-starter-test@.*$</packageUrl>
        <cpe>cpe:/a:spring:spring_boot</cpe>
    </suppress>
    
    <!-- Исключения для H2 (только для разработки) -->
    <suppress>
        <notes><![CDATA[
            H2 используется только для разработки и тестирования
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com.h2database/h2@.*$</packageUrl>
    </suppress>
    
    <!-- Исключения для dom4j с известными уязвимостями, но если версия старая -->
    <suppress>
        <notes><![CDATA[
            Если уязвимости в dom4j не критичны для приложения
            Рекомендуется обновить до версии 2.1.4+
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/dom4j/dom4j@.*$</packageUrl>
    </suppress>
    
    <!-- Исключения для Lombok (не попадает в production) -->
    <suppress>
        <notes><![CDATA[
            Lombok используется только на этапе компиляции
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org.projectlombok/lombok@.*$</packageUrl>
        <cpe>cpe:/a:projectlombok:lombok</cpe>
    </suppress>
    
</suppressions>